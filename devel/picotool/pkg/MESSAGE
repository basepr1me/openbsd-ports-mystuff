To enable direct USB control of a pico, add the following to CMakeLists.txt:

	pico_enable_stdio_usb(PROGRAM_NAME 1)

Example make script (make.sh):

```
clear
printf "\nSelect build type:\n"
printf "  [c] Clean build (destroys build directory and runs cmake)\n"
printf "  [i] Incremental build (runs make in existing build directory)\n"
printf "  [q] Quit\n"
printf "\nChoice [i]: "

read choice

if [[ $choice == "q" || $choice == "Q" ]]; then
	printf "\nExiting!\n"
	exit
fi

if [[ $choice == "c" || $choice == "C" ]]; then
	printf "\nPerforming clean build...\n\n"
	rm -rf build
	mkdir build
	cd build
	cmake -DPICO_TOOLCHAIN_PATH=/usr/local/bin ..
else
	printf "\nPerforming incremental build...\n\n"
	if [[ ! -d build ]]; then
		printf "Build directory not found! Creating and running cmake first...\n\n"
		mkdir build
		cd build
		cmake -DPICO_TOOLCHAIN_PATH=/usr/local/bin ..
	else
		cd build
	fi
fi

make

printf "\nFiles built:\n\n"
ls -lah .

printf "\nRebooting Pico to BOOTSEL mode...\n"
# Send the 1200 baud magic signal to trigger the bootloader
doas stty -f /dev/ttyU0 1200

# Give OpenBSD's USB stack a moment to drop the tty device and enumerate the Pico
sleep 2

printf "\nFlashing firmware...\n"
# Load the binary into flash and execute it immediately using a wildcard
doas picotool load -x *.uf2

printf "\nDone\n\n"
```
