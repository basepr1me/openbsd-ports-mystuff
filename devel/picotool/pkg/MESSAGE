To enable direct USB control of a pico, add the following to CMakeLists.txt:

	pico_enable_stdio_usb(PROGRAM_NAME 1)

Example make script (make.sh):

```
clear
printf "\nRUNNING THIS WILL DESTROY YOUR BUILD DIRECTORY!!!"
printf "\nDo you wish to proceed? [Y|n]: "

read proceed

if [[ $proceed != "y" && $proceed != "Y" && $proceed != "" ]]; then
	printf "\nExitting!\n"
	exit
fi

printf "\nBuilding project...\n\n";

rm -rf build
mkdir build && cd build
cmake -DPICO_TOOLCHAIN_PATH=/usr/local/bin ..
make

printf "\nFiles built:\n\n"
ls -lah .

printf "\nRebooting Pico to BOOTSEL mode...\n"
# Send the 1200 baud magic signal to trigger the bootloader
doas stty -f /dev/ttyU0 1200

# Give USB stack a moment to drop the tty device and enumerate the Pico
sleep 2

printf "\nFlashing firmware...\n"
# Load the binary into flash and execute it immediately
doas picotool load -x blink.uf2

printf "\nDone\n\n";
```
